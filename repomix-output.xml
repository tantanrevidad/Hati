              </div>

              {selectedOweUser && (
                <div className="mb-6 space-y-4">
                  {/* Payment Method Selector */}
                  <div className="flex gap-2 p-1 bg-[#F3EFE7] dark:bg-slate-800 rounded-xl">
                    {(['qrph', 'cash', 'stellar'] as const).map((method) => (
                      <button
